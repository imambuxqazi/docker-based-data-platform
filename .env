# -----------------------------
# Core application settings
# -----------------------------
LOG_LEVEL=INFO
APP_ENV=local

# -----------------------------
# PostgreSQL - application/source database
# -----------------------------
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=source_db
POSTGRES_USER=app_user
POSTGRES_PASSWORD=app_password_123

# -----------------------------
# App DB aliases used by code
# -----------------------------
APP_DB_HOST=postgres
APP_DB_PORT=5432
APP_DB_NAME=source_db
APP_DB_USER=app_user
APP_DB_PASSWORD=app_password_123

# -----------------------------
# MinIO / S3A
# -----------------------------
MINIO_ENDPOINT=http://minio:9000
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123

BRONZE_BUCKET=bronze-bucket
SILVER_BUCKET=silver-bucket
GOLD_BUCKET=gold-bucket

# -----------------------------
# Kafka / Redpanda
# -----------------------------
KAFKA_BOOTSTRAP_SERVERS=redpanda:9092
REDPANDA_BROKERS=redpanda:9092
REDPANDA_TOPIC_CLICKSTREAM=clickstream_events

# -----------------------------
# Spark
# -----------------------------
SPARK_MASTER_URL=spark://spark-master:7077
SPARK_DRIVER_MEMORY=1g
SPARK_EXECUTOR_MEMORY=1g
SPARK_SQL_SHUFFLE_PARTITIONS=8
SPARK_WORKER_CORES=2
SPARK_WORKER_MEMORY=2g

# -----------------------------
# Batch controls
# -----------------------------
CDC_BATCH_SIZE=1000
CLICKSTREAM_BATCH_SIZE=500
ORDERS_GENERATOR_SLEEP_SECONDS=5
CLICKSTREAM_GENERATOR_SLEEP_SECONDS=2

# -----------------------------
# Airflow
# -----------------------------
AIRFLOW_UID=50000
AIRFLOW_GID=0
AIRFLOW_PYTHONPATH=/opt/airflow:/opt/airflow/dags:/opt/airflow/pipelines:/opt/airflow/config:/opt/airflow/quality:/opt/airflow/analytics:/opt/airflow/alerts:/opt/airflow/data_generators

AIRFLOW__CORE__EXECUTOR=LocalExecutor
AIRFLOW__CORE__LOAD_EXAMPLES=False
AIRFLOW__CORE__DAGS_ARE_PAUSED_AT_CREATION=True
AIRFLOW__CORE__DEFAULT_TIMEZONE=UTC
AIRFLOW__CORE__FERNET_KEY=3G3nJx2v9w8mYp4rQ7sLd1vN5kTzB6cF
AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=postgresql+psycopg2://app_user:app_password_123@postgres:5432/source_db
AIRFLOW__WEBSERVER__SECRET_KEY=airflow_webserver_secret_key_local
AIRFLOW__API__AUTH_BACKENDS=airflow.api.auth.backend.session

AIRFLOW_ADMIN_USERNAME=admin
AIRFLOW_ADMIN_PASSWORD=admin123
AIRFLOW_ADMIN_FIRSTNAME=Data
AIRFLOW_ADMIN_LASTNAME=Engineer
AIRFLOW_ADMIN_EMAIL=admin@example.com
AIRFLOW_WEBSERVER_PORT=8089